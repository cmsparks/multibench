{
  "name": "multibench",
  "version": "0.0.0",
  "private": true,
  "description": "Benchmark for evaluating computer-use agent harnesses across multi-step tasks.",
  "type": "module",
  "packageManager": "pnpm@11.1.3",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.16.0"
  },
  "scripts": {
    "build": "pnpm -r --filter './packages/*' build",
    "clean": "pnpm -r --filter './packages/*' clean && rm -rf .multibench coverage",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "test": "vitest run",
    "typecheck": "pnpm -r --filter './packages/*' typecheck"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.0.0",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.3",
    "typescript": "^5.9.0",
    "typescript-eslint": "^8.59.3",
    "vitest": "^4.0.0"
  }
}
