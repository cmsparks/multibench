{
  "name": "@multibench/cli",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "bin": {
    "multibench": "./dist/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -b",
    "clean": "rm -rf dist *.tsbuildinfo",
    "typecheck": "tsc -b --pretty false"
  },
  "dependencies": {
    "@multibench/core": "workspace:*",
    "@multibench/harness": "workspace:*",
    "@multibench/runner": "workspace:*"
  }
}
